// TrackerTab
// ══════════════════════════════════════════════════
function TrackerTab({done,toggleDone,goQuiz,doneTime,remTime,pct,srs}) {
  const undone=LECTURES.filter(l=>!done.has(l.n)).sort((a,b)=>RANK_ORDER[a.rank]-RANK_ORDER[b.rank]);
  return(
    <div style={{paddingTop:20}}>
      <div style={{borderBottom:`3px double ${C.ink}`,paddingBottom:14,marginBottom:18}}>
        <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:38,fontWeight:800,lineHeight:1}}>権利<span style={{color:C.s}}>関係</span></div>
        <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:11,letterSpacing:'0.3em',color:C.muted,marginTop:4}}>講義進捗トラッカー · 82講義</div>
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr 1fr',gap:8,marginBottom:14}}>
        {[{l:'全体',b:`${done.size}`,s:`/ 82　${pct}%`,bar:true},{l:'完了',b:`${(doneTime/60).toFixed(1)}h`,s:`${doneTime}分`},{l:'残り',b:`${(remTime/60).toFixed(1)}h`,s:`${remTime}分`}].map(x=>(
          <div key={x.l} style={{background:'white',border:`1px solid ${C.line}`,padding:'10px 12px'}}>
            <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:10,letterSpacing:'0.2em',color:C.muted,marginBottom:3}}>{x.l}</div>
            <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:24,fontWeight:800,color:C.s,lineHeight:1}}>{x.b}</div>
            <div style={{fontSize:10,color:C.muted,marginTop:2}}>{x.s}</div>
            {x.bar&&<div style={{height:3,background:'#f0ece3',marginTop:5,overflow:'hidden'}}><div style={{height:'100%',width:`${pct}%`,background:`linear-gradient(90deg,${C.s},#e86030)`,transition:'width 0.5s'}}/></div>}
          </div>
        ))}
      </div>
      <div style={{background:'#fffbe8',borderLeft:'3px solid #e8b800',padding:'7px 11px',marginBottom:12,fontSize:11}}>
        💡 タスク行タップ→完了切替　／　<b>クイズ</b>ボタン→問題集へ
      </div>
      {undone.length>0&&(
        <div style={{background:'white',border:`1px solid ${C.line}`,padding:12,marginBottom:16}}>
          <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:10,letterSpacing:'0.2em',color:C.muted,marginBottom:8,borderBottom:`1px dashed ${C.line}`,paddingBottom:6}}>📚 次におすすめ</div>
          {undone.slice(0,3).map(l=>(
            <div key={l.n} onClick={()=>goQuiz(l.cat)} style={{display:'flex',alignItems:'center',gap:8,padding:'7px 8px',borderLeft:`3px solid ${rankColor(l.rank)}`,background:rankBg(l.rank),cursor:'pointer',fontSize:12,marginBottom:4,transition:'transform 0.15s'}}
              onMouseEnter={e=>e.currentTarget.style.transform='translateX(3px)'} onMouseLeave={e=>e.currentTarget.style.transform='none'}>
              <span style={{fontFamily:"'Shippori Mincho',serif",fontWeight:800,fontSize:13,color:rankColor(l.rank),minWidth:18}}>{l.n}</span>
              <span style={{flex:1,fontSize:11}}>{l.t}</span>
              <span style={{fontSize:10,color:C.muted}}>{l.m}分</span>
            </div>
          ))}
        </div>
      )}
      {RANK_CONFIG.map(rc=>{
        const rl=LECTURES.filter(l=>l.rank===rc.id);
        const rd=rl.filter(l=>done.has(l.n)).length;
        const cats=[...new Set(rl.map(l=>l.cat))];
        return(
          <div key={rc.id} style={{marginBottom:22}}>
            <div style={{display:'flex',alignItems:'center',gap:8,padding:'9px 12px',marginBottom:8,background:rankBg(rc.id),borderLeft:`4px solid ${rankColor(rc.id)}`}}>
              <span style={{fontFamily:"'Shippori Mincho',serif",fontWeight:800,fontSize:16,color:rankColor(rc.id)}}>{rc.emoji} {rc.id}</span>
              <div style={{flex:1}}>
                <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:12,fontWeight:700}}>{rc.label}</div>
                <div style={{fontSize:10,color:C.muted}}>{rc.desc}</div>
              </div>
              <span style={{fontSize:11,whiteSpace:'nowrap'}}>{rd}/{rl.length}</span>
            </div>
            {cats.map(cat=>{
              const items=rl.filter(l=>l.cat===cat);
              const cd=items.filter(l=>done.has(l.n)).length;
              // 分野の正答率
              const catQs=QB[cat]||[];
              const catRecs=catQs.map((_,i)=>srs[qid(cat,i)]).filter(Boolean);
              const catAcc=catRecs.length?Math.round(catRecs.reduce((s,r)=>s+r.correctAns,0)/catRecs.reduce((s,r)=>s+r.totalAns,0)*100):null;
              const accColor=catAcc===null?C.muted:catAcc<50?C.s:catAcc<75?C.warn:C.done;
              return(
                <div key={cat} style={{marginBottom:10}}>
                  <div style={{display:'flex',alignItems:'center',gap:6,marginBottom:5}}>
                    <span style={{fontSize:9,padding:'1px 5px',fontWeight:800,background:rankColor(rc.id),color:'white'}}>{rc.id}</span>
                    <span style={{fontFamily:"'Shippori Mincho',serif",fontSize:12,fontWeight:700}}>{cat}</span>
                    {catAcc!==null&&<span style={{fontSize:10,padding:'1px 5px',background:accColor,color:'white',fontWeight:700}}>{catAcc}%</span>}
                    <div style={{flex:1,height:1,background:C.line}}/>
                    <span style={{fontSize:10,color:C.muted}}>{cd}/{items.length}</span>
                    {QB[cat]&&<SmBtn onClick={()=>goQuiz(cat)}>✏️クイズ</SmBtn>}
                  </div>
                  <div style={{display:'flex',flexDirection:'column',gap:3}}>
                    {items.map(l=>{
                      const isDone=done.has(l.n),isCurr=l.n===CURRENT_N&&!isDone;
                      return(
                        <div key={l.n} onClick={()=>toggleDone(l.n)}
                          style={{display:'flex',alignItems:'center',gap:8,padding:'7px 10px',border:isCurr?`2px solid ${C.s}`:`1px solid ${isDone?C.doneBd:rankBd(rc.id)}`,background:isDone?C.doneBg:isCurr?'#fff8f9':'white',cursor:'pointer',transition:'all 0.15s'}}
                          onMouseEnter={e=>{if(!isDone&&!isCurr)e.currentTarget.style.background=rankBg(rc.id);}}
                          onMouseLeave={e=>{if(!isDone&&!isCurr)e.currentTarget.style.background='white';}}>
                          <div style={{width:16,height:16,border:`2px solid ${isDone?C.done:C.line}`,background:isDone?C.done:'white',display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0}}>
                            {isDone&&<span style={{color:'white',fontSize:10,fontWeight:900}}>✓</span>}
                          </div>
                          <span style={{fontFamily:"'Shippori Mincho',serif",fontWeight:800,fontSize:12,color:isDone?C.done:rankColor(rc.id),minWidth:28}}>権{l.n}</span>
                          <span style={{flex:1,fontSize:11,color:isDone?C.done:C.ink}}>{l.t}</span>
                          <span style={{fontSize:10,color:C.muted,whiteSpace:'nowrap'}}>{l.m}分</span>
                          {isCurr&&<span style={{fontSize:8,padding:'1px 4px',background:C.s,color:'white',fontWeight:700}}>学習中</span>}
                        </div>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </div>
        );
      })}
      <div style={{textAlign:'center',fontFamily:"'Shippori Mincho',serif",fontSize:10,color:C.muted,letterSpacing:'0.3em',paddingTop:20,borderTop:`1px solid ${C.line}`}}>合 格 へ の 道 · 一 歩 ず つ</div>
    </div>
  );
}

// ══════════════════════════════════════════════════
// QuizTab
// ══════════════════════════════════════════════════
function QuizTab({quizPhase,quizScope,setQuizScope,quizDiff,setQuizDiff,quizCount,setQuizCount,quizMode,setQuizMode,dueCount,q,qIdx,score,skipped,totalQ,answered,barPct,finalPct,currentRec,handleOX,nextQ,skipQ,startQuiz,backToSetup,history,srs}) {
  const allCats=[...new Set(LECTURES.map(l=>l.cat))].filter(c=>QB[c]).sort((a,b)=>RANK_ORDER[LECTURES.find(l=>l.cat===a).rank]-RANK_ORDER[LECTURES.find(l=>l.cat===b).rank]);
  const ready = quizMode==='review' ? !!quizCount : (!!quizDiff && !!quizCount);
  const qAcc  = currentRec && currentRec.totalAns>0 ? Math.round(currentRec.correctAns/currentRec.totalAns*100) : null;

  return(
    <div style={{paddingTop:20}}>
      <div style={{borderBottom:`3px double ${C.ink}`,paddingBottom:14,marginBottom:20}}>
        <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:38,fontWeight:800,lineHeight:1}}>○×<span style={{color:C.s}}>問題集</span></div>
        <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:11,letterSpacing:'0.3em',color:C.muted,marginTop:4}}>権利関係 · 忘却曲線対応</div>
      </div>

      {quizPhase==='setup'&&(
        <div>
          {/* モード選択 */}
          <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10,marginBottom:20}}>
            <div onClick={()=>setQuizMode('review')} style={{border:`2px solid ${quizMode==='review'?C.review:C.line}`,background:quizMode==='review'?C.reviewBg:'white',padding:'14px 16px',cursor:'pointer',position:'relative',transition:'all 0.15s'}}>
              <div style={{fontSize:22,marginBottom:5}}>🔔</div>
              <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:14,fontWeight:800,color:quizMode==='review'?C.review:C.ink}}>忘却曲線復習</div>
              <div style={{fontSize:11,color:C.muted,marginTop:2,lineHeight:1.5}}>期限切れ＋苦手問題<br/>を自動で優先出題</div>
              {dueCount>0&&<div style={{marginTop:6,fontSize:12,fontWeight:700,color:C.review}}>{dueCount}問が待機中</div>}
              {quizMode==='review'&&<span style={{position:'absolute',top:8,right:10,fontSize:16}}>✓</span>}
            </div>
            <div onClick={()=>setQuizMode('normal')} style={{border:`2px solid ${quizMode==='normal'?C.ink:C.line}`,background:quizMode==='normal'?'#f8f8f6':'white',padding:'14px 16px',cursor:'pointer',position:'relative',transition:'all 0.15s'}}>
              <div style={{fontSize:22,marginBottom:5}}>✏️</div>
              <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:14,fontWeight:800,color:quizMode==='normal'?C.ink:C.ink}}>分野別練習</div>
              <div style={{fontSize:11,color:C.muted,marginTop:2,lineHeight:1.5}}>分野・難易度を選んで<br/>自由に問題を解く</div>
              {quizMode==='normal'&&<span style={{position:'absolute',top:8,right:10,fontSize:16}}>✓</span>}
            </div>
          </div>

          <div style={{background:'white',border:`1px solid ${C.line}`,padding:20,marginBottom:18}}>
            {quizMode==='review'?(
              <div style={{marginBottom:16}}>
                <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:13,fontWeight:700,color:C.review,marginBottom:8}}>🔔 忘却曲線モード</div>
                <div style={{fontSize:12,color:C.muted,lineHeight:1.7,marginBottom:10}}>
                  正答率・出題間隔を自動計算して、<b>今日忘れそうな問題</b>を優先的に出題します。<br/>
                  正解するたびに次回出題までの間隔が延びます（1日→3日→7日→14日→30日）。
                </div>
                <div style={{display:'grid',gridTemplateColumns:'repeat(3,1fr)',gap:8,marginBottom:4}}>
                  {[
                    {label:'新出問題',count:Object.keys(QB).flatMap(c=>QB[c].map((_,i)=>srs[qid(c,i)])).filter(r=>!r).length,color:C.a},
                    {label:'期限切れ',count:dueCount,color:C.review},
                    {label:'正答率<50%',count:Object.entries(QB).flatMap(([c,qs])=>qs.map((_,i)=>srs[qid(c,i)])).filter(r=>r&&r.totalAns>0&&r.correctAns/r.totalAns<0.5).length,color:C.s},
                  ].map(s=>(
                    <div key={s.label} style={{background:s.color+'15',border:`1px solid ${s.color}`,padding:'8px',textAlign:'center'}}>
                      <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:20,fontWeight:800,color:s.color}}>{s.count}</div>
                      <div style={{fontSize:10,color:C.muted}}>{s.label}</div>
                    </div>
                  ))}
                </div>
              </div>
            ):(
              <>
                <Lbl>出題分野</Lbl>
                <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(148px,1fr))',gap:6,marginBottom:20}}>
                  {[{scope:'all',label:'📚 全分野ランダム',rank:null},...allCats.map(c=>({scope:c,label:c,rank:LECTURES.find(l=>l.cat===c).rank}))].map(x=>{
                    const catQs=x.scope!=='all'&&QB[x.scope]?QB[x.scope].map((_,i)=>srs[qid(x.scope,i)]).filter(Boolean):null;
                    const catAcc=catQs&&catQs.length?Math.round(catQs.reduce((s,r)=>s+r.correctAns,0)/catQs.reduce((s,r)=>s+r.totalAns,0)*100):null;
                    return(
                      <button key={x.scope} onClick={()=>setQuizScope(x.scope)} style={{padding:'8px 10px',border:`1.5px solid ${quizScope===x.scope?C.ink:C.line}`,background:quizScope===x.scope?C.ink:'white',color:quizScope===x.scope?'white':C.ink,fontFamily:"'Zen Kaku Gothic New',sans-serif",fontSize:11,fontWeight:600,cursor:'pointer',textAlign:'left',display:'flex',alignItems:'center',gap:4,transition:'all 0.15s'}}>
                        {x.rank&&<span style={{fontSize:9,padding:'1px 4px',fontWeight:800,background:quizScope===x.scope?'rgba(255,255,255,0.25)':rankColor(x.rank),color:'white'}}>{x.rank}</span>}
                        <span style={{flex:1}}>{x.label}</span>
                        {catAcc!==null&&<span style={{fontSize:10,color:quizScope===x.scope?'rgba(255,255,255,0.7)':(catAcc<50?C.s:catAcc<75?C.warn:C.done)}}>{catAcc}%</span>}
                      </button>
                    );
                  })}
                </div>
                <Lbl>難易度</Lbl>
                <div style={{display:'flex',gap:10,marginBottom:20,flexWrap:'wrap'}}>
                  {[{id:'normal',icon:'📖',name:'普通',desc:'基本ルール・典型パターン'},{id:'hard',icon:'🔥',name:'難しい',desc:'本試験レベル・例外・判例'}].map(d=>(
                    <div key={d.id} onClick={()=>setQuizDiff(d.id)} style={{flex:1,minWidth:130,border:`2px solid ${quizDiff===d.id?(d.id==='hard'?C.hard:C.a):C.line}`,background:quizDiff===d.id?(d.id==='hard'?C.hardBg:'#f0f4ff'):'white',padding:'12px 14px',cursor:'pointer',position:'relative',transition:'all 0.15s'}}>
                      <div style={{fontSize:18,marginBottom:4}}>{d.icon}</div>
                      <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:14,fontWeight:800,color:quizDiff===d.id?(d.id==='hard'?C.hard:C.a):C.ink}}>{d.name}</div>
                      <div style={{fontSize:11,color:C.muted,marginTop:2}}>{d.desc}</div>
                      {quizDiff===d.id&&<span style={{position:'absolute',top:8,right:10,fontSize:15}}>✓</span>}
                    </div>
                  ))}
                </div>
              </>
            )}
            <Lbl>問題数</Lbl>
            <div style={{display:'flex',gap:10,marginBottom:20}}>
              {[5,10].map(n=>(
                <button key={n} onClick={()=>setQuizCount(n)} style={{padding:'9px 24px',border:`2px solid ${quizCount===n?C.ink:C.line}`,background:quizCount===n?C.ink:'white',color:quizCount===n?'white':C.muted,fontFamily:"'Zen Kaku Gothic New',sans-serif",fontSize:14,fontWeight:700,cursor:'pointer',transition:'all 0.15s'}}>{n} 問</button>
              ))}
            </div>
            <button onClick={startQuiz} disabled={!ready} style={{width:'100%',padding:14,border:'none',background:ready?(quizMode==='review'?C.review:C.ink):'#ccc',color:'white',fontFamily:"'Shippori Mincho',serif",fontSize:14,fontWeight:700,letterSpacing:'0.2em',cursor:ready?'pointer':'not-allowed',transition:'background 0.2s'}}>
              {ready?(quizMode==='review'?`🔔 復習スタート →（${quizCount}問）`:`スタート →（${quizCount}問・${quizDiff==='hard'?'難しい':'普通'}）`):'問題数を選択'}
            </button>
          </div>
        </div>
      )}

      {quizPhase==='running'&&(
        <div>
          <div style={{height:5,background:'#f0ece3',marginBottom:14,overflow:'hidden'}}>
            <div style={{height:'100%',width:`${barPct}%`,background:quizMode==='review'?C.review:C.ink,transition:'width 0.4s'}}/>
          </div>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:12,flexWrap:'wrap',gap:6,fontSize:12}}>
            <span style={{fontFamily:"'Shippori Mincho',serif",fontSize:14,fontWeight:700}}>{qIdx+1} / {totalQ}</span>
            {quizMode==='review'
              ?<span style={{fontSize:11,padding:'2px 8px',fontWeight:700,background:C.reviewBg,color:C.review,border:`1px solid ${C.review}`}}>🔔 忘却曲線</span>
              :<span style={{fontSize:11,padding:'2px 8px',fontWeight:700,background:quizDiff==='hard'?C.hardBg:'#f0f4ff',color:quizDiff==='hard'?C.hard:C.a,border:`1px solid ${quizDiff==='hard'?'#d4a0c8':C.aBd}`}}>{quizDiff==='hard'?'🔥 難しい':'📖 普通'}</span>
            }
            <span style={{fontSize:11,color:C.muted}}>🎯 {quizMode==='review'?'復習':quizScope==='all'?'全分野':quizScope}</span>
            <span style={{fontSize:12}}>正解: {score}{skipped>0&&<span style={{color:C.muted,marginLeft:6}}>スキップ: {skipped}</span>}</span>
          </div>

          {/* この問題のSRS情報 */}
          {currentRec&&currentRec.totalAns>0&&(
            <div style={{display:'flex',gap:10,alignItems:'center',padding:'6px 12px',background:'#f8f8f8',border:`1px solid ${C.line}`,marginBottom:10,fontSize:11,flexWrap:'wrap'}}>
              <span style={{color:C.muted}}>この問題の履歴：</span>
              <span style={{fontWeight:700,color:qAcc<50?C.s:qAcc<75?C.warn:C.done}}>正答率 {qAcc}%</span>
              <span style={{color:C.muted}}>({currentRec.correctAns}/{currentRec.totalAns}回)</span>
              <span style={{color:C.muted}}>連続正解: {currentRec.streak}回</span>
            </div>
          )}

          <div style={{background:'white',border:`1px solid ${C.line}`,padding:'20px',marginBottom:18,minHeight:90}}>
            <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:10,letterSpacing:'0.3em',color:C.muted,marginBottom:10}}>問 {qIdx+1}　{q?.cat||''}</div>
            <div style={{fontSize:15,lineHeight:1.9,fontWeight:500}}>{q?.s}</div>
          </div>

          {answered===null&&(
            <>
              <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:12,marginBottom:10}}>
                <OXBtn type="O" onClick={()=>handleOX(true)}/>
                <OXBtn type="X" onClick={()=>handleOX(false)}/>
              </div>
              <button onClick={skipQ} style={{width:'100%',padding:10,border:`1px solid ${C.line}`,background:'white',color:C.muted,fontSize:12,cursor:'pointer',fontFamily:"'Zen Kaku Gothic New',sans-serif",marginBottom:14}}>
                わからない（スキップ →）
              </button>
            </>
          )}

          {answered!==null&&q&&(
            <>
              <div style={{padding:'16px',marginBottom:12,textAlign:'center',background:answered===q.a?C.doneBg:'#ffeaea',border:`2px solid ${answered===q.a?C.doneBd:'#e08080'}`}}>
                <div style={{fontSize:40,marginBottom:5}}>{answered===q.a?'⭕':'❌'}</div>
                <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:15,fontWeight:800,color:answered===q.a?C.done:C.s}}>{answered===q.a?'正解！':'不正解'}</div>
                <div style={{fontSize:13,color:C.muted,marginTop:3}}>正解は　<span style={{fontFamily:"'Shippori Mincho',serif",fontWeight:800,fontSize:20,color:q.a?C.o:C.x}}>{q.a?'○':'×'}</span></div>
                {/* 次回出題日 */}
                {q.id&&srs[q.id]&&(
                  <div style={{fontSize:11,color:C.muted,marginTop:8}}>
                    次回出題：{Math.round((srs[q.id].nextDate-today0())/864e5)}日後
                    　連続正解：{srs[q.id].streak}回
                  </div>
                )}
              </div>
              <div style={{background:'#f0ece3',borderLeft:`3px solid ${C.ink}`,padding:'12px 14px',marginBottom:12,fontSize:13,lineHeight:1.9}}>
                <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:10,letterSpacing:'0.2em',color:C.muted,marginBottom:6}}>解 説</div>
                <div>{q.e}</div>
              </div>
              <button onClick={nextQ} style={{width:'100%',padding:13,border:'none',background:quizMode==='review'?C.review:C.ink,color:'white',fontFamily:"'Shippori Mincho',serif",fontSize:13,fontWeight:700,letterSpacing:'0.2em',cursor:'pointer',marginBottom:8,transition:'background 0.2s'}}
                onMouseEnter={e=>e.target.style.opacity='0.85'} onMouseLeave={e=>e.target.style.opacity='1'}>
                {qIdx>=totalQ-1?'結果を見る →':'次の問題 →'}
              </button>
            </>
          )}
          <button onClick={backToSetup} style={{width:'100%',padding:9,border:`1px solid ${C.line}`,background:'white',color:C.muted,fontSize:12,cursor:'pointer',fontFamily:"'Zen Kaku Gothic New',sans-serif"}}>中止して設定に戻る</button>
        </div>
      )}

      {quizPhase==='result'&&(
        <div style={{background:'white',border:`1px solid ${C.line}`,padding:'30px 20px',textAlign:'center',marginBottom:20}}>
          <div style={{fontSize:48,marginBottom:12}}>{finalPct>=80?'🏆':finalPct>=60?'📚':'💪'}</div>
          <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:18,fontWeight:800,marginBottom:5}}>{finalPct>=80?'合格圏内！':finalPct>=60?'もう一息！':'復習が必要'}</div>
          <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:48,fontWeight:800,color:C.s,lineHeight:1,margin:'14px 0'}}>{score} <span style={{fontSize:16,color:C.muted}}>/ {totalQ-skipped}</span></div>
          <div style={{fontSize:13,color:C.muted,marginBottom:8,lineHeight:1.8}}>
            正答率 {finalPct}%{skipped>0&&`（スキップ ${skipped}問）`}
            {finalPct>=80&&' この調子で仕上げましょう！'}{finalPct>=60&&finalPct<80&&' 解説を読み返しましょう。'}{finalPct<60&&skipped<totalQ&&' 基本から確認し直しましょう。'}
          </div>
