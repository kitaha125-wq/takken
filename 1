// ══════════════════════════════════════════════════
// SRS（間隔反復学習）ロジック
// ══════════════════════════════════════════════════
// qRecord の構造:
// { streak: 連続正解数, nextDate: 次回出題日のtimestamp(ms), totalAns: 総回答数, correctAns: 正解数 }

function loadSRS() { return sg('tk_srs_v1', {}); }
function saveSRS(data) { ss('tk_srs_v1', data); }

function getNextInterval(streak) {
  const intervals = SRS_INTERVALS;
  const idx = Math.min(streak, intervals.length - 1);
  return intervals[idx];
}

function recordAnswer(srs, id, correct) {
  const rec = srs[id] || { streak:0, nextDate:0, totalAns:0, correctAns:0 };
  const newRec = {
    streak:    correct ? rec.streak + 1 : 0,
    totalAns:  rec.totalAns + 1,
    correctAns:rec.correctAns + (correct ? 1 : 0),
    nextDate:  today0() + getNextInterval(correct ? rec.streak + 1 : 0) * 864e5,
  };
  return { ...srs, [id]: newRec };
}

// 今日出題すべき問題を取得
function getDueQuestions(srs) {
  const now = today0();
  const due = [];
  Object.entries(QB).forEach(([cat, qs]) => {
    qs.forEach((q, idx) => {
      const id = qid(cat, idx);
      const rec = srs[id];
      if (!rec || rec.nextDate <= now) {
        due.push({ ...q, id, cat, idx,
          streak: rec?.streak || 0,
          accuracy: rec ? Math.round(rec.correctAns / rec.totalAns * 100) : null,
          totalAns: rec?.totalAns || 0,
        });
      }
    });
  });
  return due;
}

// 問題を優先度順にソート
// 優先度: ①未回答 ②正答率低い ③streakが低い ④期限切れ古い順
function sortByPriority(questions, srs) {
  return [...questions].sort((a, b) => {
    const ra = srs[a.id], rb = srs[b.id];
    // 未回答を最優先
    if (!ra && rb) return -1;
    if (ra && !rb) return 1;
    if (!ra && !rb) return 0;
    // 正答率が低い順
    const accA = ra.correctAns / ra.totalAns;
    const accB = rb.correctAns / rb.totalAns;
    if (Math.abs(accA - accB) > 0.1) return accA - accB;
    // streak が低い順
    return ra.streak - rb.streak;
  });
}

// 通常クイズ用ピック（SRS考慮）
function pickQuestions(scope, count, srs) {
  let pool = scope === 'all'
    ? Object.entries(QB).flatMap(([cat, qs]) => qs.map((q, idx) => ({...q, id:qid(cat,idx), cat})))
    : (QB[scope] || []).map((q, idx) => ({...q, id:qid(scope,idx), cat:scope}));

  const now = today0();
  // 期限切れ（今日出題すべき）を優先
  const due    = sortByPriority(pool.filter(q => { const r=srs[q.id]; return !r || r.nextDate <= now; }), srs);
  const notDue = pool.filter(q => { const r=srs[q.id]; return r && r.nextDate > now; }).sort(()=>Math.random()-0.5);

  const selected = [...due, ...notDue].slice(0, count);
  // 足りなければランダム補完
  if (selected.length < count) {
    const extra = pool.filter(q => !selected.find(s=>s.id===q.id)).sort(()=>Math.random()-0.5);
    selected.push(...extra.slice(0, count - selected.length));
  }
  return selected.slice(0, count);
}

