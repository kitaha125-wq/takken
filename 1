// CalendarTab
// ══════════════════════════════════════════════════
function CalendarTab({daysDone,toggleDay,goQuiz}) {
  const today=new Date();today.setHours(0,0,0,0);
  const MONTHS=[{year:2026,month:4,label:'2026年 5月'},{year:2026,month:5,label:'2026年 6月'}];
  const [selectedDay,setSelectedDay]=useState(null);
  const DOW=['日','月','火','水','木','金','土'];
  const weekColors={'第1週':C.a,'第2週':C.s,'第3週':'#2d7a3a','第4週':C.hard,'予備日':C.b};

  function buildCalendar(year,month){
    const first=new Date(year,month,1);
    const last=new Date(year,month+1,0);
    const cells=[];
    for(let i=0;i<first.getDay();i++) cells.push(null);
    for(let d=1;d<=last.getDate();d++){
      const date=new Date(year,month,d);date.setHours(0,0,0,0);
      const planDay=dateToPlanDay(date);
      const sched=planDay?SCHEDULE.find(s=>s.day===planDay):null;
      const isToday=date.getTime()===today.getTime();
      cells.push({d,date,planDay,sched,isToday});
    }
    return cells;
  }
  const selectedSched=selectedDay?SCHEDULE.find(s=>s.day===selectedDay):null;

  return(
    <div style={{paddingTop:20}}>
      <div style={{borderBottom:`3px double ${C.ink}`,paddingBottom:14,marginBottom:18}}>
        <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:38,fontWeight:800,lineHeight:1}}>学習<span style={{color:C.s}}>カレンダー</span></div>
        <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:11,letterSpacing:'0.3em',color:C.muted,marginTop:4}}>5月〜6月 · 28日間学習計画</div>
      </div>
      <div style={{display:'flex',gap:10,flexWrap:'wrap',marginBottom:14,fontSize:11}}>
        {Object.entries(weekColors).map(([w,col])=>(
          <div key={w} style={{display:'flex',alignItems:'center',gap:4}}>
            <div style={{width:10,height:10,background:col}}/><span style={{color:C.muted}}>{w}</span>
          </div>
        ))}
        <div style={{display:'flex',alignItems:'center',gap:4}}><div style={{width:10,height:10,border:`2px solid ${C.ink}`}}/><span style={{color:C.muted}}>今日</span></div>
        <div style={{display:'flex',alignItems:'center',gap:4}}><div style={{width:10,height:10,background:C.done}}/><span style={{color:C.muted}}>完了</span></div>
      </div>
      {MONTHS.map(({year,month,label})=>{
        const cells=buildCalendar(year,month);
        return(
          <div key={label} style={{marginBottom:24}}>
            <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:15,fontWeight:800,marginBottom:10,letterSpacing:'0.1em'}}>{label}</div>
            <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)',gap:2,marginBottom:2}}>
              {DOW.map((d,i)=><div key={d} style={{textAlign:'center',fontSize:11,fontWeight:700,color:i===0?C.s:i===6?C.a:C.muted,padding:'4px 0'}}>{d}</div>)}
            </div>
            <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)',gap:2}}>
              {cells.map((cell,i)=>{
                if(!cell) return <div key={`e${i}`}/>;
                const{d,planDay,sched,isToday}=cell;
                const isDone=planDay&&daysDone.has(planDay);
                const isSelected=planDay&&selectedDay===planDay;
                const col=sched?weekColors[sched.week]:null;
                const dow=cell.date.getDay();
                return(
                  <div key={d} onClick={()=>{if(planDay)setSelectedDay(isSelected?null:planDay);}}
                    style={{minHeight:46,border:isToday?`2px solid ${C.ink}`:isSelected?`2px solid ${col||C.ink}`:`1px solid ${C.line}`,background:isDone?C.doneBg:sched?`${col}18`:'white',cursor:planDay?'pointer':'default',padding:'3px 4px',position:'relative',transition:'all 0.15s'}}>
                    <div style={{fontFamily:"'Shippori Mincho',serif",fontWeight:800,fontSize:13,color:dow===0?C.s:dow===6?C.a:isDone?C.done:sched?col:C.muted,lineHeight:1}}>{d}</div>
                    {planDay&&<div style={{fontSize:9,fontWeight:700,color:isDone?C.done:col||C.muted,marginTop:2}}>D{planDay}</div>}
                    {isDone&&<div style={{position:'absolute',bottom:2,right:3,fontSize:11,color:C.done}}>✓</div>}
                    {sched?.review&&<div style={{position:'absolute',top:1,right:2,fontSize:8,color:col}}>復</div>}
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
      {selectedSched&&(
        <div style={{border:`2px solid ${selectedSched.color}`,background:'white',padding:'16px 18px',marginBottom:20}}>
          <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:10,flexWrap:'wrap'}}>
            <span style={{fontSize:10,padding:'2px 8px',fontWeight:800,background:selectedSched.color,color:'white'}}>Day {selectedSched.day}</span>
            <span style={{fontFamily:"'Shippori Mincho',serif",fontSize:13,fontWeight:700,color:selectedSched.color}}>{selectedSched.week} · {selectedSched.theme}</span>
          </div>
          <div style={{fontSize:13,lineHeight:1.8,marginBottom:14}}>{selectedSched.task}</div>
          <button onClick={()=>toggleDay(selectedSched.day)}
            style={{padding:'8px 16px',border:`2px solid ${daysDone.has(selectedSched.day)?C.done:C.line}`,background:daysDone.has(selectedSched.day)?C.doneBg:'white',color:daysDone.has(selectedSched.day)?C.done:C.muted,fontWeight:700,fontSize:12,cursor:'pointer',transition:'all 0.15s',fontFamily:"'Zen Kaku Gothic New',sans-serif"}}>
            {daysDone.has(selectedSched.day)?'✓ 完了済み':'完了にする'}
          </button>
        </div>
      )}
      <div style={{marginTop:10}}>
        <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:12,fontWeight:700,letterSpacing:'0.1em',color:C.muted,marginBottom:10,borderBottom:`1px dashed ${C.line}`,paddingBottom:6}}>全タスク一覧</div>
        {['第1週','第2週','第3週','第4週','予備日'].map(week=>{
          const days=SCHEDULE.filter(s=>s.week===week);
          const wDone=days.filter(d=>daysDone.has(d.day)).length;
          const col=weekColors[week];
          return(
            <div key={week} style={{marginBottom:14}}>
              <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:6,paddingBottom:5,borderBottom:`2px solid ${col}`}}>
                <span style={{fontFamily:"'Shippori Mincho',serif",fontWeight:800,fontSize:12,color:col}}>{week}</span>
                <span style={{fontSize:11,color:C.muted,flex:1}}>{days[0]?.theme}</span>
                <span style={{fontSize:11,color:C.muted}}>{wDone}/{days.length}</span>
              </div>
              {days.map(d=>{
                const isDone=daysDone.has(d.day);
                return(
                  <div key={d.day} onClick={()=>{toggleDay(d.day);setSelectedDay(d.day);}}
                    style={{display:'flex',gap:10,alignItems:'flex-start',padding:'9px 11px',marginBottom:3,background:isDone?C.doneBg:'white',border:`1px solid ${isDone?C.doneBd:C.line}`,cursor:'pointer',transition:'all 0.15s'}}>
                    <div style={{width:16,height:16,border:`2px solid ${isDone?C.done:C.line}`,background:isDone?C.done:'white',display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0,marginTop:2}}>
                      {isDone&&<span style={{color:'white',fontSize:10,fontWeight:900}}>✓</span>}
                    </div>
                    <div style={{flex:1}}>
                      {d.review&&<span style={{fontSize:9,padding:'1px 5px',background:col,color:'white',fontWeight:800,marginRight:5,display:'inline-block',marginBottom:2}}>復習</span>}
                      {d.extra&&<span style={{fontSize:9,padding:'1px 5px',background:C.b,color:'white',fontWeight:800,marginRight:5,display:'inline-block',marginBottom:2}}>予備</span>}
                      <span style={{fontSize:10,color:C.muted,marginRight:6}}>Day {d.day}</span>
                      <span style={{fontSize:12,lineHeight:1.7,color:isDone?C.done:C.ink,textDecoration:isDone?'line-through':'none'}}>{d.task}</span>
                    </div>
                  </div>
                );
              })}
            </div>
          );
        })}
      </div>
    </div>
  );
}

