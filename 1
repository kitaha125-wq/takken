          <div style={{display:'flex',gap:10,justifyContent:'center',flexWrap:'wrap'}}>
            <button onClick={startQuiz} style={{padding:'11px 22px',border:`2px solid ${C.ink}`,background:'white',fontFamily:"'Zen Kaku Gothic New',sans-serif",fontSize:12,fontWeight:700,cursor:'pointer'}}>もう一度</button>
            <button onClick={backToSetup} style={{padding:'11px 22px',border:'none',background:C.ink,color:'white',fontFamily:"'Zen Kaku Gothic New',sans-serif",fontSize:12,fontWeight:700,cursor:'pointer'}}>設定に戻る</button>
          </div>
        </div>
      )}

      {quizPhase!=='running'&&(
        <div style={{marginTop:18}}>
          <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:11,letterSpacing:'0.2em',color:C.muted,marginBottom:8,borderBottom:`1px dashed ${C.line}`,paddingBottom:6}}>📊 最近の成績</div>
          {history.length===0?<div style={{fontSize:12,color:C.muted,padding:8}}>まだ記録がありません</div>
            :history.map((h,i)=>(
              <div key={i} style={{display:'flex',gap:8,alignItems:'center',padding:'8px 11px',background:'white',border:`1px solid ${C.line}`,marginBottom:4,fontSize:12,flexWrap:'wrap'}}>
                <span style={{color:C.muted,minWidth:75}}>{h.date}</span>
                <span style={{fontFamily:"'Shippori Mincho',serif",fontWeight:700,fontSize:14,color:h.pct>=80?C.done:h.pct>=60?C.a:C.s}}>{h.score}/{h.total-(h.skipped||0)}（{h.pct}%）</span>
                <span style={{fontSize:11}}>{h.scope}</span>
                {h.interrupted&&<span style={{fontSize:10,padding:'1px 6px',fontWeight:700,background:C.warnBg,color:C.warn,border:`1px solid ${C.warn}`}}>中断</span>}
                <span style={{marginLeft:'auto',fontSize:11,color:C.muted}}>{h.diff} {h.interrupted?`${h.total}/${h.planned||h.total}問（中断）`: `${h.total}問`}{h.skipped>0&&` · スキップ${h.skipped}`}</span>
              </div>
            ))
          }
        </div>
      )}
    </div>
  );
}

function OXBtn({type,onClick}){
  const[hov,setHov]=useState(false);const isO=type==='O';
  return(
    <button onClick={onClick} onMouseEnter={()=>setHov(true)} onMouseLeave={()=>setHov(false)}
      style={{padding:'20px 10px',border:`3px solid ${isO?C.o:C.x}`,background:hov?(isO?C.o:C.x):'white',color:hov?'white':(isO?C.o:C.x),cursor:'pointer',transition:'all 0.15s',display:'flex',flexDirection:'column',alignItems:'center',gap:5}}>
      <span style={{fontSize:44,lineHeight:1,fontFamily:"'Shippori Mincho',serif",fontWeight:800}}>{isO?'○':'×'}</span>
      <span style={{fontSize:12,fontWeight:700,letterSpacing:'0.1em',fontFamily:"'Shippori Mincho',serif"}}>{isO?'正しい':'誤り'}</span>
    </button>
  );
}
function Lbl({children}){return <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:11,fontWeight:700,letterSpacing:'0.1em',color:C.muted,marginBottom:8}}>{children}</div>;}
function SmBtn({onClick,children}){
  const[hov,setHov]=useState(false);
  return <button onClick={onClick} onMouseEnter={()=>setHov(true)} onMouseLeave={()=>setHov(false)} style={{fontSize:10,padding:'2px 7px',border:`1px solid ${C.ink}`,background:hov?C.ink:'white',color:hov?'white':C.ink,cursor:'pointer',fontWeight:700,transition:'all 0.15s',fontFamily:"'Zen Kaku Gothic New',sans-serif"}}>{children}</button>;
}


