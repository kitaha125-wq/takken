// 分野別正答率パネル
function SRSStats({srs}) {
  const cats = Object.keys(QB);
  const stats = cats.map(cat=>{
    const qs = QB[cat].map((q,i)=>srs[qid(cat,i)]).filter(Boolean);
    if(!qs.length) return {cat, acc:null, total:0, correct:0, count:qs.length};
    const total   = qs.reduce((s,r)=>s+r.totalAns,0);
    const correct = qs.reduce((s,r)=>s+r.correctAns,0);
    return {cat, acc:total?Math.round(correct/total*100):null, total, correct, count:qs.length};
  }).filter(s=>s.total>0).sort((a,b)=>a.acc-b.acc);

  if(!stats.length) return null;
  return (
    <div style={{marginBottom:16}}>
      <div style={{fontFamily:"'Shippori Mincho',serif",fontSize:12,fontWeight:700,letterSpacing:'0.1em',color:C.muted,marginBottom:10,borderBottom:`1px dashed ${C.line}`,paddingBottom:6}}>📊 分野別正答率</div>
      {stats.map(s=>{
        const col = s.acc<50?C.s:s.acc<75?C.warn:C.done;
        const rank = LECTURES.find(l=>l.cat===s.cat)?.rank||'B';
        return(
          <div key={s.cat} style={{display:'flex',alignItems:'center',gap:10,marginBottom:7}}>
            <span style={{fontSize:9,padding:'1px 5px',fontWeight:800,background:rankColor(rank),color:'white',minWidth:16,textAlign:'center'}}>{rank}</span>
            <span style={{fontSize:11,minWidth:110,fontWeight:s.acc<50?700:400,color:s.acc<50?C.s:C.ink}}>{s.cat}</span>
            <div style={{flex:1,height:8,background:'#f0ece3',overflow:'hidden',borderRadius:0}}>
              <div style={{height:'100%',width:`${s.acc}%`,background:col,transition:'width 0.5s'}}/>
            </div>
            <span style={{fontSize:11,fontWeight:700,color:col,minWidth:36,textAlign:'right'}}>{s.acc}%</span>
            <span style={{fontSize:10,color:C.muted,minWidth:40,textAlign:'right'}}>{s.correct}/{s.total}</span>
          </div>
        );
      })}
    </div>
  );
}

