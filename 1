// メインアプリ
// ══════════════════════════════════════════════════
function App() {
  const [tab,setTab]             = useState('home');
  const [done,setDone]           = useState(()=>new Set(sg('tk_done_v5',INITIAL_DONE)));
  const [daysDone,setDaysDone]   = useState(()=>new Set(sg('tk_days_v5',[])));
  const [srs,setSRS]             = useState(()=>loadSRS());
  const [quizScope,setQuizScope] = useState('all');
  const [quizDiff,setQuizDiff]   = useState(null);
  const [quizCount,setQuizCount] = useState(null);
  const [quizMode,setQuizMode]   = useState('normal'); // 'normal' | 'review'
  const [quizPhase,setQuizPhase] = useState('setup');
  const [questions,setQuestions] = useState([]);
  const [qIdx,setQIdx]           = useState(0);
  const [score,setScore]         = useState(0);
  const [skipped,setSkipped]     = useState(0);
  const [answered,setAnswered]   = useState(null);
  const [history,setHistory]     = useState(()=>sg('tk_hist_v5',[]));

  const daysLeft     = getDaysLeft();
  const todayPlanDay = getTodayPlanDay();
  const todayTask    = todayPlanDay ? SCHEDULE.find(s=>s.day===todayPlanDay) : null;
  const dueQuestions = getDueQuestions(srs);
  const dueCount     = dueQuestions.length;

  const toggleDone = useCallback(n=>{
    setDone(prev=>{const nx=new Set(prev);nx.has(n)?nx.delete(n):nx.add(n);ss('tk_done_v5',[...nx]);return nx;});
  },[]);
  const toggleDay = useCallback(d=>{
    setDaysDone(prev=>{const nx=new Set(prev);nx.has(d)?nx.delete(d):nx.add(d);ss('tk_days_v5',[...nx]);return nx;});
  },[]);
  const goQuiz = useCallback((cat, mode='normal')=>{
    setQuizScope(cat); setQuizMode(mode); setTab('quiz'); setQuizPhase('setup');
    window.scrollTo({top:0,behavior:'smooth'});
  },[]);
  const startReviewNow = useCallback(()=>{
    setQuizMode('review'); setTab('quiz'); setQuizPhase('setup');
    window.scrollTo({top:0,behavior:'smooth'});
  },[]);

  const doneTime = LECTURES.filter(l=>done.has(l.n)).reduce((s,l)=>s+l.m,0);
  const remTime  = TOTAL_TIME - doneTime;
  const pct      = Math.round(done.size/LECTURES.length*100);

  const startQuiz = useCallback(()=>{
    if(!quizCount) return;
    let qs;
    if (quizMode === 'review') {
      // 忘却曲線モード：期限切れ優先＋正答率低い順
      const prioritized = sortByPriority(dueQuestions, srs);
      qs = prioritized.slice(0, quizCount);
      if (qs.length < quizCount) {
        const extra = pickQuestions('all', quizCount - qs.length, srs).filter(q=>!qs.find(x=>x.id===q.id));
        qs = [...qs, ...extra];
      }
    } else {
      qs = pickQuestions(quizScope, quizCount, srs);
    }
    setQuestions(qs.map(q=>({...q}))); setQIdx(0); setScore(0); setSkipped(0); setAnswered(null); setQuizPhase('running');
  },[quizCount, quizMode, quizScope, dueQuestions, srs]);

  const handleOX = useCallback(ans=>{
    if(answered!==null) return;
    setAnswered(ans);
    const correct = ans === questions[qIdx]?.a;
    if(correct) setScore(s=>s+1);
    // SRS 更新
    const q = questions[qIdx];
    if (q?.id) {
      const newSRS = recordAnswer(srs, q.id, correct);
      setSRS(newSRS);
      saveSRS(newSRS);
    }
  },[answered,questions,qIdx,srs]);

  const saveSessionHistory = useCallback((opts={})=>{
    const {interrupted=false,finalSkipped=skipped,finalScore=score}=opts;
    let attempted,total;
    if(interrupted){
      const dealt=qIdx+(answered!==null?1:0);
      attempted=dealt-finalSkipped;
      if(dealt===0) return;
      total=dealt;
    } else {
      attempted=quizCount-finalSkipped;
      total=quizCount;
    }
    const p=attempted>0?Math.round(finalScore/attempted*100):0;
    const entry={date:new Date().toLocaleString('ja-JP',{month:'numeric',day:'numeric',hour:'2-digit',minute:'2-digit'}),score:finalScore,total,pct:p,skipped:finalSkipped,interrupted,planned:quizCount,diff:quizDiff||'—',scope:quizMode==='review'?'📚復習モード':quizScope==='all'?'全分野':quizScope};
    setHistory(prev=>{const nh=[entry,...prev].slice(0,15);ss('tk_hist_v5',nh);return nh;});
  },[qIdx,answered,skipped,score,quizCount,quizDiff,quizMode,quizScope]);

  const nextQ = useCallback(()=>{
    if(qIdx+1>=quizCount){
      setQuizPhase('result');
      saveSessionHistory({interrupted:false});
    } else { setQIdx(i=>i+1); setAnswered(null); }
  },[qIdx,quizCount,saveSessionHistory]);

  const skipQ = useCallback(()=>{
    if(answered!==null) return;
    const newSkipped=skipped+1;
    setSkipped(newSkipped);
    if(qIdx+1>=quizCount){
      setQuizPhase('result');
      saveSessionHistory({interrupted:false,finalSkipped:newSkipped});
    } else { setQIdx(i=>i+1); setAnswered(null); }
  },[answered,qIdx,quizCount,skipped,saveSessionHistory]);

  const abortQuiz = useCallback(()=>{
    if(quizPhase==='running') saveSessionHistory({interrupted:true});
    setQuizPhase('setup');
  },[quizPhase,saveSessionHistory]);

  const q=questions[qIdx]; const totalQ=quizCount||5;
  const barPct=quizPhase==='running'?Math.round(qIdx/totalQ*100):0;
  const attempted=totalQ-skipped;
  const finalPct=quizPhase==='result'?(attempted>0?Math.round(score/attempted*100):0):0;
  const currentRec = q?.id ? srs[q.id] : null;

  const TABS=[['home','🏠','ホーム'],['calendar','📅','計画'],['tracker','📋','進捗'],['quiz','✏️','問題集']];

  return (
    <div style={{fontFamily:"'Zen Kaku Gothic New',sans-serif",background:C.paper,minHeight:'100vh',color:C.ink}}>
      <nav style={{position:'sticky',top:0,zIndex:100,background:C.ink,display:'flex'}}>
        {TABS.map(([id,icon,label])=>(
          <button key={id} onClick={()=>setTab(id)} style={{flex:1,padding:'10px 4px',border:'none',background:'transparent',color:tab===id?'white':'rgba(255,255,255,0.4)',fontFamily:"'Shippori Mincho',serif",cursor:'pointer',borderBottom:tab===id?`3px solid ${C.s}`:'3px solid transparent',transition:'all 0.2s',display:'flex',flexDirection:'column',alignItems:'center',gap:1}}>
            <span style={{fontSize:16}}>{icon}</span>
            <span style={{fontSize:9,fontWeight:700,letterSpacing:'0.04em'}}>{label}</span>
          </button>
        ))}
      </nav>
      <div style={{maxWidth:800,margin:'0 auto',padding:'0 14px 80px'}}>
        {tab==='home'    &&<HomeTab daysLeft={daysLeft} todayTask={todayTask} todayPlanDay={todayPlanDay} done={done} pct={pct} doneTime={doneTime} remTime={remTime} daysDone={daysDone} dueCount={dueCount} srs={srs} setTab={setTab} goQuiz={goQuiz} startReviewNow={startReviewNow}/>}
        {tab==='calendar'&&<CalendarTab daysDone={daysDone} toggleDay={toggleDay} goQuiz={goQuiz}/>}
        {tab==='tracker' &&<TrackerTab done={done} toggleDone={toggleDone} goQuiz={goQuiz} doneTime={doneTime} remTime={remTime} pct={pct} srs={srs}/>}
        {tab==='quiz'    &&<QuizTab quizPhase={quizPhase} quizScope={quizScope} setQuizScope={setQuizScope} quizDiff={quizDiff} setQuizDiff={setQuizDiff} quizCount={quizCount} setQuizCount={setQuizCount} quizMode={quizMode} setQuizMode={setQuizMode} dueCount={dueCount} q={q} qIdx={qIdx} score={score} skipped={skipped} totalQ={totalQ} answered={answered} barPct={barPct} finalPct={finalPct} currentRec={currentRec} handleOX={handleOX} nextQ={nextQ} skipQ={skipQ} startQuiz={startQuiz} backToSetup={abortQuiz} history={history} srs={srs}/>}
      </div>
    </div>
  );
}

